APP_PORT=3000
POSTGRES_PORT=5432
POSTGRES_CONNECT_TIMEOUT_MS=1500
POSTGRES_IDLE_TIMEOUT_MS=30000
POSTGRES_POOL_MAX=10
POSTGRES_POOL_VERIFY_INTERVAL_MS=15000
POSTGRES_APPLICATION_NAME=sisdmk2-app
DASHBOARD_CACHE_TTL_MS=30000
DASHBOARD_DATA_CACHE_TTL_MS=30000

JWT_SECRET=
NEXTAUTH_SECRET=
APP_URL=http://alamat-server-anda:3000
APP_ORIGIN=http://alamat-server-anda:3000
ALLOW_INSECURE_LOCAL_HTTP=true
COOKIE_SECURE=false

# Untuk PostgreSQL CasaOS/container existing. Script deploy akan menghubungkan
# container app dan database ke network sisdmk2-network.
POSTGRES_HOST=sisdmk-postgres
POSTGRES_HOSTS=sisdmk-postgres,host.docker.internal,172.17.0.1,postgres,db,127.0.0.1

POSTGRES_DATABASE=si_data
POSTGRES_DATABASES=si_data

POSTGRES_USER=sisdmk_admin
POSTGRES_PASSWORD=
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=/app/storage
OPENAI_API_KEY=
AI_ENABLE_N8N=true
AI_MAX_QUERY_ROWS=50
AI_QUERY_TIMEOUT=10000
AI_ALLOWED_TABLES=pegawai
AI_POSTGRES_USER=ai_readonly
AI_POSTGRES_PASSWORD=
N8N_WEBHOOK_URL=https://n8n.example.go.id/webhook/sisdmk-ai
N8N_PUBLIC_WEBHOOK_URL=https://n8n.example.go.id/webhook/sisdmk-public-chat
N8N_API_SECRET=
N8N_WEBHOOK_TIMEOUT_MS=20000
N8N_WEBHOOK_RETRIES=1
# Set this on the n8n container so workflow nodes can reach SI-SDMK app.
SISDMK_APP_BASE_URL=http://sisdmk2-app:3000
AI_DOCUMENT_CLASSIFIER_PROVIDER=mock
AI_DOCUMENT_MAX_BYTES=10485760
REDIS_URL=redis://redis:6379/0
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_GRAPH_VERSION=v20.0
CHATBOT_AUTO_REPLY=false
